# TrustBridge Backend Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://trustbridge:trustbridge@localhost:5432/trustbridgedb

# ============================================
# JWT AUTHENTICATION
# ============================================
# Generate a secure key with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-generate-a-secure-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================
# SOLANA BLOCKCHAIN
# ============================================
SOLANA_RPC_URL=https://api.devnet.solana.com
WALLET_PATH=~/.config/solana/id.json
SOLANA_SIGNER_SECRET_KEY=  # Optional: Base58-encoded secret key for signing transactions
DEVNET_USDC_MINT=  # Optional: Devnet USDC mint address for testing

# Program IDs (Solana program addresses)
CERTIFICATE_PROGRAM_ID=D7SYneSxju3iTtJW9HPQMVjQRXgTCZi2vR2UWRk8nTRa
STARTUP_PROGRAM_ID=DqwhC5DDZZmL4E1f4YYQJ9R121NurZV8ttk2dfGoYnTj
INVESTMENT_PROGRAM_ID=FEQJZDk4afcXbSrRj7iW3PieNtrmeT2Hjtt5BCmoNfRr

# Blockchain Scripts Path
BLOCKCHAIN_SCRIPTS_PATH=../blockchain/scripts

# ============================================
# AI SERVICE
# ============================================
# Get your API key from: https://mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here
# Deprecated - kept for backward compatibility
OPENAI_API_KEY=

# ============================================
# JOB PLATFORM API KEYS
# ============================================
# RemoteOK: Free - no API key needed
# Arbeitnow: Free - no API key needed

# Freelancer.com OAuth Token (optional)
# Get from: https://www.freelancer.com/api-docs
FREELANCER_OAUTH_TOKEN=
FREELANCER_SANDBOX=False

# Adzuna API (free tier: 250 requests/day)
# Get from: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_API_KEY=

# RapidAPI Key (for Y-Combinator Jobs and Internships)
# Get from: https://rapidapi.com/
RAPIDAPI_KEY=

# ============================================
# OAUTH CONFIGURATION
# ============================================
# Google OAuth
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# LinkedIn OAuth (for future implementation)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=

# Facebook OAuth (for future implementation)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=

# ============================================
# APPLICATION SETTINGS
# ============================================
APP_NAME=TrustBridge API
APP_VERSION=1.0.0
DEBUG=True
FRONTEND_URL=http://localhost:3000

# ============================================
# FILE UPLOAD SETTINGS
# ============================================
UPLOAD_DIR=static/uploads
MAX_UPLOAD_SIZE=5242880
ALLOWED_IMAGE_TYPES=["image/jpeg", "image/png", "image/jpg", "image/webp"]

# ============================================
# SECURITY SETTINGS
# ============================================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# ============================================
# ATTESTATION SERVICE SETTINGS
# ============================================
ATTESTATION_MODE=development
VERIFY_API_KEY=
VERIFY_API_URL=
CIVIC_API_KEY=
CIVIC_API_URL=
SAS_API_KEY=
SAS_API_URL=https://attest.solana.com

# Solana Attestation Flags
USE_REAL_SOLANA=True
USE_REAL_VERIFIERS=False
SOLANA_CLUSTER=devnet
